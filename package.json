    "characterize:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.61.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "prettier": "^3.8.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1"
  }
}
